rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// Community Hub — Firestore Security Rules
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function callerEmail() {
      return request.auth.token.email;
    }

    // Collapsed to a single get() call.
    // exists() + get() = 2 external reads — Firestore aggregation queries
    // (count()) only allow 1 external read per rule evaluation, so the old
    // pattern caused permission-denied on every RunAggregationQuery call
    // from admin.js. A single get() returns null if the doc is missing, and
    // null != 'admin', so the exists() guard is not needed.
    function isAdmin() {
      // BUG FIX: get() on a missing document returns a resource with null data,
      // which causes .data.role to throw a NullPointerException in Rules, producing
      // permission-denied instead of false. Guard with an explicit null check first.
      let _doc = get(/databases/$(database)/documents/users/$(callerEmail()));
      return isSignedIn() && _doc != null && _doc.data.role == 'admin';
    }

    function isOwner(data) {
      return isSignedIn() && (
        data.authorEmail == callerEmail() ||
        data.authorUid   == request.auth.uid
      );
    }

    // ── Global Live Chat ──────────────────────────────────────────────────
    // All authenticated users can read and create messages.
    // Users may only edit/delete their own messages (soft-delete via isDeleted
    // flag; mediaUrl and text are nulled). Admins can hard-delete any message.
    // Reactions (a map field) may be updated by any signed-in user.
    match /global_chat/{messageId} {
      allow read: if isSignedIn();

      // FIX 1: operator-precedence bug — the original `||` between the two
      // text checks made the entire `allow create` condition always-true for
      // any signed-in user, because `text == null` is a top-level OR clause.
      // Wrapping both alternatives in parentheses fixes the precedence so
      // senderEmail and isDeleted are always enforced.
      allow create: if isSignedIn() &&
        request.resource.data.senderEmail == callerEmail() &&
        request.resource.data.isDeleted   == false &&
        (request.resource.data.text is string || request.resource.data.text == null);

      // Own update: author may edit text/editedAt or soft-delete (isDeleted,
      // mediaUrl, text set to null). Immutable fields are explicitly blocked.
      // Reactions-only update: any signed-in user may toggle their reaction.
      // Admins: unrestricted updates.
      allow update: if isSignedIn() && (
        (resource.data.senderEmail == callerEmail() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['senderEmail', 'senderName', 'senderAvatar', 'timestamp'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])) ||
        isAdmin()
      );

      // FIX 2: hard deletes were blocked for the message author (only admins
      // could delete). Live chat uses soft-delete (isDeleted flag), but a
      // hard delete rule matching the author prevents Firestore from returning
      // permission-denied if the client ever calls deleteDoc directly.
      // Keeping hard-delete admin-only is the correct policy; soft-delete via
      // updateDoc is the author path — no change needed, documented clearly.
      allow delete: if isAdmin();
    }

    // ── Global Presence ───────────────────────────────────────────────────
    // Each user writes only their own presence document (keyed by email).
    // Dots in email addresses are valid Firestore document IDs; no escaping
    // needed at the rules level — callerEmail() is matched verbatim.
    match /global_presence/{userEmail} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && callerEmail() == userEmail;
    }

    // ── Global Typing Indicators ──────────────────────────────────────────
    // Document key is derived from the caller's email by typingDocKey() in JS:
    //   email.replace(/[^a-zA-Z0-9]/g, c => 'x' + c.charCodeAt(0).toString(16).padStart(2,'0'))
    //
    // FIX-3: replaceAll() is NOT available in Firestore Rules despite being
    // listed in some docs — the emulator rejects it. replace() only replaces
    // the FIRST occurrence, so we cannot reconstruct the full key in Rules for
    // emails with multiple dots/special chars.
    //
    // Solution: the typing collection is low-sensitivity ephemeral data (TTL
    // ~5 s). We allow any signed-in user to write any key. The JS always
    // derives the key deterministically from the caller's own email, so
    // cross-user key pollution is only possible if a user deliberately crafts
    // a collision — harmless since typing indicators auto-expire and carry no
    // private data. Reads are also open to signed-in users (needed to show
    // "X is typing…" to all participants).
    match /global_typing/{typingKey} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Lost & Found ──────────────────────────────────────────────────────
    match /lost_found/{itemId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.authorEmail == callerEmail();

      allow update, delete: if isOwner(resource.data) || isAdmin();
    }

    // ── Reports (moderation queue) ────────────────────────────────────────
    // allow read covers get, list, AND count() aggregation queries.
    match /reports/{reportId} {
      allow read: if isAdmin();

      // RP-02: Livechat.js submitReport() writes status:'pending' (lowercase).
      // The old rule checked == 'Pending' (capital-P) causing every create to
      // be denied with a silent permission error. Accept both casings so
      // legacy reports (if any) also validate, but the canonical value is now
      // lowercase 'pending' in the JS writer.
      allow create: if isSignedIn() &&
        request.resource.data.reporterEmail == callerEmail() &&
        (request.resource.data.status == 'pending' ||
         request.resource.data.status == 'Pending');

      allow update, delete: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{userEmail} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && callerEmail() == userEmail;

      allow update: if isAdmin() || (
        isSignedIn() &&
        callerEmail() == userEmail &&
        request.resource.data.role == resource.data.role
      );

      allow delete: if isAdmin();

      // ── Achievements subcollection ────────────────────────────────────
      // Carried over from production rules — was missing from the live-chat
      // output file (FIX 4: re-added).
      match /achievements/{achievementId} {
        allow read:  if isSignedIn();
        allow write: if isSignedIn() && callerEmail() == userEmail;
      }
    }

    // ── Top-level /messages collection (legacy DMs) ───────────────────────
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.to   == callerEmail() ||
        resource.data.from == callerEmail()
      );
      allow create: if isSignedIn() &&
        request.resource.data.from == callerEmail();
      allow update, delete: if isSignedIn() && (
        resource.data.from == callerEmail() || isAdmin()
      );
    }

    // ── Audit logs ────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // ── Media cleanup queue ───────────────────────────────────────────────
    // When a message is deleted-for-everyone or its media is replaced, the
    // client writes the old Cloudinary URL(s) here so a Cloud Function can
    // call Cloudinary's authenticated destroy endpoint server-side.
    // Only the message owner may create a cleanup record; only admins and
    // Cloud Functions (via the Admin SDK, which bypasses rules) may delete.
    match /media_cleanup/{cleanupId} {
      allow create: if isSignedIn() &&
        request.resource.data.requestedBy == callerEmail();
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // ── Platform settings ─────────────────────────────────────────────────
    match /platform_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Posts ─────────────────────────────────────────────────────────────
    // Broadcast posts (isBroadcast == true) are admin-only writes.
    // Regular users must not set isBroadcast, broadcastCategory,
    // broadcastTitle, pinned, or status — those fields are reserved for the
    // admin broadcast system. Non-owner reactions/votes may update upvotedBy
    // and upvoteCount but cannot touch any broadcast or authorship fields.
    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && (
        // Admin path: can create any post including broadcasts (isBroadcast:true).
        // authorEmail must still match the caller so broadcasts are attributable.
        (isAdmin() && request.resource.data.authorEmail == callerEmail()) ||
        // Regular user path: must own the post and must NOT set any
        // broadcast-reserved fields that could spoof a system announcement.
        (request.resource.data.authorEmail == callerEmail() &&
         !request.resource.data.keys().hasAny(
           ['isBroadcast', 'broadcastCategory', 'broadcastTitle']))
      );

      allow update: if isOwner(resource.data) || isAdmin() ||
        // Non-owner signed-in users (e.g. voting, bookmarking) may update
        // reaction/engagement fields but are blocked from touching content,
        // authorship, or any broadcast control field.
        (isSignedIn() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['authorEmail', 'authorUid', 'content', 'title',
                     'isBroadcast', 'broadcastCategory', 'broadcastTitle',
                     'pinned', 'status']));

      allow delete: if isOwner(resource.data) || isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn() &&
          request.resource.data.authorEmail == callerEmail();

        allow update: if isOwner(resource.data) || isAdmin() ||
          (isSignedIn() &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['authorEmail', 'authorUid', 'text', 'author']));

        allow delete: if isOwner(resource.data) || isAdmin();
      }
    }

    // ── Events & Polls ────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.authorEmail == callerEmail();

      allow update: if isOwner(resource.data) || isAdmin() ||
        (isSignedIn() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['authorEmail', 'authorUid', 'content', 'title']));

      allow delete: if isOwner(resource.data) || isAdmin();
    }

    // ── Chats ─────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      // SECURITY FIX: removed `resource.data.type == 'group'` blanket read
      // permission that allowed any signed-in user to read any group chat,
      // exposing message previews and member lists to non-members.
      // Now only members (or admins) may read a chat document.
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.members.hasAny([callerEmail()]) ||
        isAdmin()
      );

      allow create: if isSignedIn() &&
        request.resource.data.members.hasAny([callerEmail()]);

      allow update: if isSignedIn() && (
        // Admins: unrestricted.
        isAdmin() ||
        // Members may update anything except admin-controlled fields.
        (resource.data.members.hasAny([callerEmail()]) &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['type', 'createdBy', 'admins', 'inviteCode'])) ||
        // Non-members submitting a join request may only touch these two fields.
        (resource.data.type == 'group' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['pendingRequests', 'dismissedRequests']))
      );

      allow delete: if isSignedIn() && (
        // BUG FIX: private chat delete was restricted to members only — admins
        // could not remove a private chat that violated policy. Added isAdmin().
        resource.data.type == 'private'
          ? (resource.data.members.hasAny([callerEmail()]) || isAdmin())
          : (resource.data.createdBy == callerEmail() || isAdmin())
      );

      // ── Messages subcollection ─────────────────────────────────────────
      match /messages/{messageId} {
        function isChatMember() {
          let chatRef = /databases/$(database)/documents/chats/$(chatId);
          return exists(chatRef) &&
                 get(chatRef).data.members.hasAny([callerEmail()]);
        }

        allow read: if isSignedIn() && isChatMember();

        allow create: if isSignedIn() && (
          (isChatMember() && (
            request.resource.data.senderEmail == callerEmail() ||
            request.resource.data.senderEmail == 'system'
          )) ||
          (!isChatMember() &&
            exists(/databases/$(database)/documents/chats/$(chatId)) &&
            get(/databases/$(database)/documents/chats/$(chatId)).data.type == 'group' &&
            request.resource.data.senderEmail == 'system')
        );

        allow update: if isSignedIn() && (
          // ── Admin: unrestricted ──────────────────────────────────────────
          isAdmin() ||

          // ── Message owner: may edit text, replace media, soft-delete.
          // Immutable fields (senderEmail, senderName, createdAt, replyTo,
          // forwarded) are blocked so an owner cannot impersonate another
          // sender or rewrite the message history.
          // seenBy and deletedFor are member-controlled fields — the owner
          // must not be able to forge read receipts or hide messages from
          // specific members.
          (resource.data.senderEmail == callerEmail() &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['senderEmail', 'senderName', 'createdAt',
                       'replyTo', 'forwarded', 'seenBy', 'deletedFor'])) ||

          // ── Any chat member: may update only seenBy, deletedFor, reactions.
          // Content-bearing and metadata fields remain locked so members
          // cannot edit or delete each other's messages through this path.
          // FIX #7: _deletedMediaUrls added to the blocked list — only the
          // message owner (handled by the owner path above) may write this
          // field. Without this guard any member could write arbitrary
          // Cloudinary URLs to trigger server-side cleanup of assets they
          // don't own, potentially deleting another user's media.
          // Per-attachment actions (replace/delete) write to 'attachments'.
          // Only the message owner may modify that field (owner path above).
          // Lock it here so other members cannot remove or swap someone else's files.
          (isChatMember() &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['text', 'imageUrl', 'voiceUrl', 'fileUrl',
                       'isDeletedForEveryone', 'senderEmail', 'senderName',
                       'edited', 'editedAt', 'replyTo', 'forwarded',
                       'fileName', 'fileMime', 'fileSize', '_deletedMediaUrls',
                       'attachments']))
        );

        allow delete: if isSignedIn() && (
          resource.data.senderEmail == callerEmail() || isAdmin()
        );
      }

      // ── Typing indicators subcollection ───────────────────────────────
      match /typing/{typingUserEmail} {
        // FIX: exists() guard prevents throw when parent chat doc is missing.
        allow read: if isSignedIn() &&
          exists(/databases/$(database)/documents/chats/$(chatId)) &&
          get(/databases/$(database)/documents/chats/$(chatId))
            .data.members.hasAny([callerEmail()]);

        allow write: if isSignedIn() && callerEmail() == typingUserEmail;
      }

      // ── Starred messages subcollection ────────────────────────────────
      match /starred/{starredUserEmail} {
        allow read: if isSignedIn() && callerEmail() == starredUserEmail;

        allow write: if isSignedIn() &&
          callerEmail() == starredUserEmail &&
          get(/databases/$(database)/documents/chats/$(chatId))
            .data.members.hasAny([callerEmail()]);
      }
    }
  }
}