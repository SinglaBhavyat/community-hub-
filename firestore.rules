rules_version = '2';
// ─────────────────────────────────────────────────────────────────────────
// Community Hub — Firestore Security Rules
// ─────────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Helper functions ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function callerEmail() {
      return request.auth.token.email;
    }
    function isAdmin() {
      // RULE-01 FIX: guard _doc.data != null before accessing .role.
      // get() returns null when the document doesn't exist; without the
      // data null-check, accessing _doc.data.role throws a null-dereference
      // error in Firestore rules, causing the calling rule to silently deny
      // instead of evaluating cleanly.
      let _doc = get(/databases/$(database)/documents/users/$(callerEmail()));
      return isSignedIn() && _doc != null && _doc.data != null && _doc.data.role == 'admin';
    }
    function isOwner(data) {
      return isSignedIn() && (
        data.authorEmail == callerEmail() ||
        data.authorUid   == request.auth.uid
      );
    }
    // BAN ENFORCEMENT: admin.js's "Suspend" button only ever set isBanned:true
    // on the user's own doc — nothing server-side ever checked it, so a
    // suspended user could keep posting/chatting/etc. through direct Firestore
    // writes. isBanned() is the server-side backstop; it's required (OR'd with
    // isAdmin() as an escape hatch) on every content-creation rule below.
    function isBanned() {
      let _doc = get(/databases/$(database)/documents/users/$(callerEmail()));
      return isSignedIn() && _doc != null && _doc.data != null &&
        _doc.data.get('isBanned', false) == true;
    }

    // ── collectionGroup: comments ─────────────────────────────────────────
    // FIX: achievements.js uses collectionGroup(db, 'comments') to count all
    // comments made by a user across every post. Firestore requires a
    // recursive-wildcard rule (/{path=**}/...) at the top level of the rules
    // block for collectionGroup queries to be permitted. The nested rule under
    // /posts/{postId}/comments/{commentId} alone is insufficient — it only
    // covers direct subcollection reads, not collectionGroup queries, which
    // Firestore denies with "Missing or insufficient permissions" without this
    // top-level match.
    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorEmail == callerEmail() &&
        (!isBanned() || isAdmin());
      allow update: if isOwner(resource.data) || isAdmin() ||
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reactions', 'likes', 'likeCount', 'likedBy', 'replies']));
      allow delete: if isOwner(resource.data) || isAdmin();
    }

    // ── Global Live Chat ──────────────────────────────────────────────────
    match /global_chat/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.senderEmail == callerEmail() &&
        request.resource.data.isDeleted   == false &&
        (request.resource.data.text is string || request.resource.data.text == null) &&
        (!isBanned() || isAdmin());
      allow update: if isSignedIn() && (
        (resource.data.senderEmail == callerEmail() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['text', 'editedAt', 'mediaUrl', 'mediaType', 'fileName',
                      'fileSize', 'attachments', 'isDeleted', 'voiceUrl'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) &&
          request.resource.data.reactions is map &&
          (
            !resource.data.keys().hasAll(['reactions']) ||
            resource.data.reactions is map
          ) &&
          request.resource.data.reactions.diff(
            resource.data.get('reactions', {})
          ).affectedKeys().hasOnly(
            request.resource.data.reactions.keys()
          )
        ) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    // ── Global Presence ───────────────────────────────────────────────────
    match /global_presence/{userEmail} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && callerEmail() == userEmail;
    }
    match /global_typing/{typingKey} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && typingKey == callerEmail();
    }
    // ── Lost & Found ──────────────────────────────────────────────────────
    match /lost_found/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorEmail == callerEmail() &&
        // Block admin-only sentinel fields. Note: resolvedAt and resolvedAtMs are
        // written as null on create (not blocked here) — only prevent a non-null
        // pre-resolved document from being submitted at creation time.
        !request.resource.data.keys().hasAny(['isResolved', 'adminNote', 'resolvedBy']) &&
        request.resource.data.get('resolved', false) == false &&
        request.resource.data.get('resolvedAtMs', null) == null &&
        (!isBanned() || isAdmin());
      allow update, delete: if isOwner(resource.data) || isAdmin();
    }
    match /reports/{reportId} {
      allow read: if isAdmin();
      // FIX: accept both 'Pending' (written by eventsAndPolls.js) and 'pending'
      // for backwards compatibility. Previously the rule only matched lowercase
      // 'pending', which silently denied every report submission because the
      // client payload uses 'Pending' (capital P).
      allow create: if isSignedIn() &&
        request.resource.data.reporterEmail == callerEmail() &&
        request.resource.data.status in ['pending', 'Pending'];
      allow update, delete: if isAdmin();
    }
    match /users/{userEmail} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && callerEmail() == userEmail;
      allow update: if isAdmin() || (
        isSignedIn() &&
        callerEmail() == userEmail &&
        // RULE-FIX-SAVEDPOSTS: allow users to update their own profile fields
        // (name, bio, savedPosts, notifications, preferences, etc.) but prevent
        // self-elevation of role. Previously this rule only checked role equality
        // which is correct, but did not explicitly permit any fields — combined
        // with Firestore's implicit field validation, savedPosts writes were
        // silently denied in some rule configurations.
        request.resource.data.role == resource.data.role
      );
      allow delete: if isAdmin();
      match /achievements/{achievementId} {
        allow read: if isSignedIn();
        // FIX: previously `write: if isAdmin()` which permanently blocked
        // maybeCheckAndPersist() in achievements.js from recording unlocked
        // achievements for regular users. Users must be able to write their
        // own achievement documents (identified by the parent {userEmail}
        // wildcard matching their own email). Admin retains full write access.
        allow write: if isAdmin() ||
          (isSignedIn() && callerEmail() == userEmail);
      }
    }
    match /messages/{messageId} {
      allow read: if isSignedIn() && resource != null && (
        resource.data.to   == callerEmail() ||
        resource.data.from == callerEmail()
      );
      allow create: if isSignedIn() &&
        request.resource.data.from == callerEmail();
      allow update: if isSignedIn() && (
        (resource.data.from == callerEmail() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['from', 'to'])
        ) || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.from == callerEmail() || isAdmin()
      );
    }
    match /audit_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }
    match /media_cleanup/{cleanupId} {
      allow create: if isSignedIn() &&
        request.resource.data.requestedBy == callerEmail() &&
        request.resource.data.keys().hasAll(['requestedBy', 'publicIds']) &&
        request.resource.data.publicIds is list;
      allow read, delete: if isAdmin();
      allow update: if false;
    }
    // ── Platform settings ─────────────────────────────────────────────────
    // INTENTIONALLY public read — main.js subscribes to platform_settings/global
    // at cold startup (before auth resolves) to gate maintenance mode on every
    // page including the login screen.  isSignedIn() here breaks that listener
    // and cascades into "Could not open chat." on mobile.  The document only
    // holds `maintenanceMode: boolean`.  Writes remain admin-only.
    match /platform_settings/{settingId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        (isAdmin() && request.resource.data.authorEmail == callerEmail()) ||
        (request.resource.data.authorEmail == callerEmail() &&
         !isBanned() &&
         !request.resource.data.keys().hasAny(
           ['isBroadcast', 'broadcastCategory', 'broadcastTitle']))
      );
      // BUG-FIX-RULE-COMMENTCOUNT: removed 'commentCount' from the non-owner
      // allow-list. commentCount is incremented atomically via writeBatch inside
      // the comments module (addDoc + updateDoc in one transaction). Listing it
      // here let any signed-in user write an arbitrary integer to commentCount,
      // corrupting post comment totals without posting a comment.
      // isOwner / isAdmin already permit commentCount writes for legitimate edits.
      allow update: if isOwner(resource.data) || isAdmin() ||
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reactions', 'likes', 'likeCount', 'views', 'viewCount',
                      'upvotedBy', 'upvoteCount',
                      'attendance', 'poll', 'studyMembers']));
      allow delete: if isOwner(resource.data) || isAdmin();
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.authorEmail == callerEmail() &&
          (!isBanned() || isAdmin());
        allow update: if isOwner(resource.data) || isAdmin() ||
          (isSignedIn() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['reactions', 'likes', 'likeCount', 'likedBy', 'replies']));
        allow delete: if isOwner(resource.data) || isAdmin();
      }
    }
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorEmail == callerEmail() &&
        (!isBanned() || isAdmin());
      allow update: if isOwner(resource.data) || isAdmin() ||
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reactions', 'likes', 'likeCount', 'attendees', 'attendeeCount',
                      'rsvps', 'pollVotes']));
      allow delete: if isOwner(resource.data) || isAdmin();
    }
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        resource == null ||
        resource.data.members.hasAny([callerEmail()]) ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
        request.resource.data.members.hasAny([callerEmail()]) &&
        request.resource.data.members.size() <= 200 &&
        (!isBanned() || isAdmin());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.members.hasAny([callerEmail()]) &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['type', 'createdBy', 'admins', 'inviteCode', 'members']) &&
          (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['lastRead']) ||
            (resource.data.lastRead != null &&
              request.resource.data.lastRead
                .diff(resource.data.lastRead).affectedKeys()
                .hasOnly([callerEmail()])
            ) ||
            (resource.data.lastRead == null &&
              request.resource.data.lastRead.keys().hasOnly([callerEmail()])
            )
          ) &&
          (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['unreadCount']) ||
            (resource.data.unreadCount != null &&
              request.resource.data.unreadCount
                .diff(resource.data.unreadCount).affectedKeys()
                .hasOnly([callerEmail()])
            ) ||
            (resource.data.unreadCount == null &&
              request.resource.data.unreadCount.keys().hasOnly([callerEmail()])
            )
          )
        ) ||
        // ── Join-request writes (open / request-to-join groups) ───────────
        // FIX RULE-04 (3 bugs in one branch):
        //   (a) Ternary ? : is NOT valid syntax in Firestore Security Rules.
        //       The rules compiler rejects it at deploy time — no traffic reaches
        //       any rule below this branch in the update rule.
        //   (b) list.diff(list) does not exist in Firestore rules. .diff() is a
        //       Map method; calling it on a list throws a null-dereference during
        //       rule evaluation, silently denying every matched request.
        //   (c) .addedKeys() is a MapDiff method — it is not available on the
        //       result of a (hypothetical) list diff either.
        //
        // Fix: use list.toSet().difference(otherSet) which IS valid in rules v2
        // and correctly computes the set of emails added/removed.
        // We verify that ONLY the caller's own email appears in either the
        // added-set or the removed-set, preventing injection of other emails.
        (resource.data.type == 'group' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['pendingRequests']) &&
          // Emails added to pendingRequests must only be the caller's
          request.resource.data.pendingRequests.toSet()
            .difference(resource.data.get('pendingRequests', []).toSet())
            .hasOnly([callerEmail()]) &&
          // Emails removed from pendingRequests must only be the caller's
          resource.data.get('pendingRequests', []).toSet()
            .difference(request.resource.data.pendingRequests.toSet())
            .hasOnly([callerEmail()])
        ) ||
        (resource.data.type == 'group' &&
          resource.data.admins is list &&
          resource.data.admins.hasAny([callerEmail()]) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'memberNames', 'admins', 'inviteCode', 'pendingRequests', 'dismissedRequests'])
        ) ||
        (resource.data.members.hasAny([callerEmail()]) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'memberNames', 'admins']) &&
          !request.resource.data.members.hasAny([callerEmail()])
        )
      );
      // FIX RULE-06: private chat delete previously used `createdBy == callerEmail()`.
      // Private chat documents are created by openChatRoom via setDoc with only
      // { type, members, memberNames, lastUpdated } — the `createdBy` field is
      // NEVER written for private chats.  Using createdBy here means
      // resource.data.createdBy is always null, so null == callerEmail() is always
      // false, permanently blocking every non-admin user from deleting any private
      // chat.  Correct check: any member of the private chat may delete it
      // (both participants should be able to remove their conversation).
      // Group chats correctly keep the existing `createdBy` restriction.
      allow delete: if isSignedIn() && (
        resource.data.type == 'private'
          ? (resource.data.members.hasAny([callerEmail()]) || isAdmin())
          : ((resource.data.keys().hasAll(['createdBy']) &&
               resource.data.createdBy == callerEmail()) || isAdmin())
      );
      match /messages/{messageId} {
        function getChatOnce() {
          return get(/databases/$(database)/documents/chats/$(chatId));
        }
        function isChatMember() {
          let _chat = getChatOnce();
          return _chat != null && _chat.data.members.hasAny([callerEmail()]);
        }
        function getChatDoc() {
          return getChatOnce();
        }
        function isSystemMsgAllowed() {
          let _c = getChatDoc();
          return _c != null &&
                 _c.data.type == 'group' &&
                 request.resource.data.senderEmail == 'system';
        }
        allow read: if isSignedIn() && isChatMember();
        allow create: if isSignedIn() && (!isBanned() || isAdmin()) && (
          isChatMember()
            ? (request.resource.data.senderEmail == callerEmail() ||
               request.resource.data.senderEmail == 'system')
            : isSystemMsgAllowed()
        );
        allow update: if isSignedIn() && (
          isAdmin() ||
          (resource.data.senderEmail == callerEmail() &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['senderEmail', 'senderName', 'createdAt',
                       'replyTo', 'forwarded', 'seenBy', 'deletedFor'])) ||
          (isChatMember() &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['text', 'imageUrl', 'voiceUrl', 'fileUrl',
                       'isDeletedForEveryone', 'senderEmail', 'senderName',
                       'edited', 'editedAt', 'replyTo', 'forwarded',
                       'fileName', 'fileMime', 'fileSize', '_deletedMediaUrls',
                       'attachments']))
        );
        allow delete: if isSignedIn() && (
          resource.data.senderEmail == callerEmail() || isAdmin()
        );
      }
      match /typing/{typingUserEmail} {
        function callerIsTypingMember() {
          let _c = get(/databases/$(database)/documents/chats/$(chatId));
          return _c != null && _c.data.members.hasAny([callerEmail()]);
        }
        allow read:  if isSignedIn() && callerIsTypingMember();
        allow write: if isSignedIn() &&
                        callerEmail() == typingUserEmail &&
                        callerIsTypingMember();
      }
      match /starred/{starredUserEmail} {
        function callerIsStarredMember() {
          let _c = get(/databases/$(database)/documents/chats/$(chatId));
          return _c != null && _c.data.members.hasAny([callerEmail()]);
        }
        allow read:  if isSignedIn() && callerEmail() == starredUserEmail;
        allow write: if isSignedIn() &&
                        callerEmail() == starredUserEmail &&
                        callerIsStarredMember();
      }
    }
  }
}