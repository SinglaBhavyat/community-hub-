rules_version = '2';
// ─────────────────────────────────────────────────────────────────────────
// Community Hub — Firestore Security Rules
// ─────────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Helper functions ──────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function callerEmail() {
      return request.auth.token.email;
    }
    function isAdmin() {
      // RULE-01 FIX: guard _doc.data != null before accessing .role.
      // get() returns null when the document doesn't exist; without the
      // data null-check, accessing _doc.data.role throws a null-dereference
      // error in Firestore rules, causing the calling rule to silently deny
      // instead of evaluating cleanly.
      let _doc = get(/databases/$(database)/documents/users/$(callerEmail()));
      return isSignedIn() && _doc != null && _doc.data != null && _doc.data.role == 'admin';
    }
    function isOwner(data) {
      return isSignedIn() && (
        data.authorEmail == callerEmail() ||
        data.authorUid   == request.auth.uid
      );
    }
    // BAN ENFORCEMENT: admin.js's "Suspend" button only ever set isBanned:true
    // on the user's own doc — nothing server-side ever checked it, so a
    // suspended user could keep posting/chatting/etc. through direct Firestore
    // writes. isBanned() is the server-side backstop; it's required (OR'd with
    // isAdmin() as an escape hatch) on every content-creation rule below.
    function isBanned() {
      let _doc = get(/databases/$(database)/documents/users/$(callerEmail()));
      return isSignedIn() && _doc != null && _doc.data != null &&
        _doc.data.get('isBanned', false) == true;
    }

    // ── collectionGroup: comments ─────────────────────────────────────────
    // FIX: achievements.js uses collectionGroup(db, 'comments') to count all
    // comments made by a user across every post. Firestore requires a
    // recursive-wildcard rule (/{path=**}/...) at the top level of the rules
    // block for collectionGroup queries to be permitted. The nested rule under
    // /posts/{postId}/comments/{commentId} alone is insufficient — it only
    // covers direct subcollection reads, not collectionGroup queries, which
    // Firestore denies with "Missing or insufficient permissions" without this
    // top-level match.
    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorEmail == callerEmail() &&
        (!isBanned() || isAdmin());
      allow update: if isOwner(resource.data) || isAdmin() ||
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reactions', 'likes', 'likeCount', 'likedBy', 'replies']));
      allow delete: if isOwner(resource.data) || isAdmin();
    }

    // ── Global Live Chat ──────────────────────────────────────────────────
    match /global_chat/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.senderEmail == callerEmail() &&
        request.resource.data.isDeleted   == false &&
        (request.resource.data.text is string || request.resource.data.text == null) &&
        (!isBanned() || isAdmin());
      allow update: if isSignedIn() && (
        (resource.data.senderEmail == callerEmail() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['text', 'editedAt', 'mediaUrl', 'mediaType', 'fileName',
                      'fileSize', 'attachments', 'isDeleted', 'voiceUrl'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) &&
          request.resource.data.reactions is map &&
          (
            !resource.data.keys().hasAll(['reactions']) ||
            resource.data.reactions is map
          ) &&
          request.resource.data.reactions.diff(
            resource.data.get('reactions', {})
          ).affectedKeys().hasOnly(
            request.resource.data.reactions.keys()
          )
        ) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
    // ── Global Presence ───────────────────────────────────────────────────
    match /global_presence/{userEmail} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && callerEmail() == userEmail;
    }
    match /global_typing/{typingKey} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && typingKey == callerEmail();
    }
    // ── Lost & Found ──────────────────────────────────────────────────────
    match /lost_found/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorEmail == callerEmail() &&
        // Block admin-only sentinel fields. Note: resolvedAt and resolvedAtMs are
        // written as null on create (not blocked here) — only prevent a non-null
        // pre-resolved document from being submitted at creation time.
        !request.resource.data.keys().hasAny(['isResolved', 'adminNote', 'resolvedBy']) &&
        request.resource.data.get('resolved', false) == false &&
        request.resource.data.get('resolvedAtMs', null) == null &&
        (!isBanned() || isAdmin());
      allow update, delete: if isOwner(resource.data) || isAdmin();
    }
    match /reports/{reportId} {
      allow read: if isAdmin();
      // FIX: accept both 'Pending' (written by eventsAndPolls.js) and 'pending'
      // for backwards compatibility. Previously the rule only matched lowercase
      // 'pending', which silently denied every report submission because the
      // client payload uses 'Pending' (capital P).
      allow create: if isSignedIn() &&
        request.resource.data.reporterEmail == callerEmail() &&
        request.resource.data.status in ['pending', 'Pending'];
      allow update, delete: if isAdmin();
    }
    match /users/{userEmail} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && callerEmail() == userEmail;
      allow update: if isAdmin() || (
        isSignedIn() &&
        callerEmail() == userEmail &&
        // RULE-FIX-SAVEDPOSTS: allow users to update their own profile fields
        // (name, bio, savedPosts, notifications, preferences, etc.) but prevent
        // self-elevation of role. Previously this rule only checked role equality
        // which is correct, but did not explicitly permit any fields — combined
        // with Firestore's implicit field validation, savedPosts writes were
        // silently denied in some rule configurations.
        request.resource.data.role == resource.data.role
      );
      allow delete: if isAdmin();
      match /achievements/{achievementId} {
        allow read: if isSignedIn();
        // FIX: previously `write: if isAdmin()` which permanently blocked
        // maybeCheckAndPersist() in achievements.js from recording unlocked
        // achievements for regular users. Users must be able to write their
        // own achievement documents (identified by the parent {userEmail}
        // wildcard matching their own email). Admin retains full write access.
        allow write: if isAdmin() ||
          (isSignedIn() && callerEmail() == userEmail);
      }
    }
    match /messages/{messageId} {
      allow read: if isSignedIn() && resource != null && (
        resource.data.to   == callerEmail() ||
        resource.data.from == callerEmail()
      );
      allow create: if isSignedIn() &&
        request.resource.data.from == callerEmail();
      allow update: if isSignedIn() && (
        (resource.data.from == callerEmail() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['from', 'to'])
        ) || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.from == callerEmail() || isAdmin()
      );
    }
    match /audit_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }
    match /media_cleanup/{cleanupId} {
      allow create: if isSignedIn() &&
        request.resource.data.requestedBy == callerEmail() &&
        request.resource.data.keys().hasAll(['requestedBy', 'publicIds']) &&
        request.resource.data.publicIds is list;
      allow read, delete: if isAdmin();
      allow update: if false;
    }
    // ── Platform settings ─────────────────────────────────────────────────
    // INTENTIONALLY public read — main.js subscribes to platform_settings/global
    // at cold startup (before auth resolves) to gate maintenance mode on every
    // page including the login screen.  isSignedIn() here breaks that listener
    // and cascades into "Could not open chat." on mobile.  The document only
    // holds `maintenanceMode: boolean`.  Writes remain admin-only.
    match /platform_settings/{settingId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        (isAdmin() && request.resource.data.authorEmail == callerEmail()) ||
        (request.resource.data.authorEmail == callerEmail() &&
         !isBanned() &&
         !request.resource.data.keys().hasAny(
           ['isBroadcast', 'broadcastCategory', 'broadcastTitle']))
      );
      // BUG-FIX-RULE-COMMENTCOUNT: removed 'commentCount' from the non-owner
      // allow-list. commentCount is incremented atomically via writeBatch inside
      // the comments module (addDoc + updateDoc in one transaction). Listing it
      // here let any signed-in user write an arbitrary integer to commentCount,
      // corrupting post comment totals without posting a comment.
      // isOwner / isAdmin already permit commentCount writes for legitimate edits.
      allow update: if isOwner(resource.data) || isAdmin() ||
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reactions', 'likes', 'likeCount', 'views', 'viewCount',
                      'upvotedBy', 'upvoteCount',
                      'attendance', 'poll', 'studyMembers']));
      allow delete: if isOwner(resource.data) || isAdmin();
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.authorEmail == callerEmail() &&
          (!isBanned() || isAdmin());
        allow update: if isOwner(resource.data) || isAdmin() ||
          (isSignedIn() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['reactions', 'likes', 'likeCount', 'likedBy', 'replies']));
        allow delete: if isOwner(resource.data) || isAdmin();
      }
    }
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorEmail == callerEmail() &&
        (!isBanned() || isAdmin());
      allow update: if isOwner(resource.data) || isAdmin() ||
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reactions', 'likes', 'likeCount', 'attendees', 'attendeeCount',
                      'rsvps', 'pollVotes']));
      allow delete: if isOwner(resource.data) || isAdmin();
    }
    match /chats/{chatId} {
      // BUG-READ-QUERY FIX: `resource == null` does NOT grant collection-query access.
      // Firestore only sets resource==null for get() on a non-existent doc; for list/query
      // requests (onSnapshot with where-filter) resource is unavailable and the expression
      // throws, causing permission-denied on every RCM listener.
      //
      // Fix: use `allow get` / `allow list` (Firestore v2 sub-operations of `read`).
      //   • list: caller must be signed in — safe because the query always carries a
      //     `members array-contains callerEmail()` filter, so Firestore only ever returns
      //     docs the caller is already a member of. Without this the RCM snapshot
      //     subscription fails immediately with permission-denied.
      //   • get:  require explicit membership or admin on direct single-doc fetches.
      allow list: if isSignedIn();
      // FIX JOIN-GET: tx.get() inside the join-group transaction fires a single-doc
      // get on the group the user wants to join — but they are NOT a member yet, so
      // the old membership-only guard always denies it with permission-denied.
      // Add a narrow third condition: any signed-in user may read a group doc whose
      // inviteCode field is non-empty (i.e. the group is explicitly invite-joinable).
      // This is intentional — the invite code is the access credential; anyone who
      // has it should be able to look up the group. The list rule already allows the
      // initial getDocs query; this makes the subsequent tx.get() consistent with it.
      allow get:  if isSignedIn() && (
        resource == null ||
        resource.data.members.hasAny([callerEmail()]) ||
        (resource.data.type == 'group' && resource.data.get('inviteCode', '') != '') ||
        isAdmin()
      );
      allow create: if isSignedIn() &&
        request.resource.data.members.hasAny([callerEmail()]) &&
        request.resource.data.members.size() <= 200 &&
        (!isBanned() || isAdmin());
      allow update: if isSignedIn() && (
        isAdmin() ||
        // ── Send-message room-metadata branch ─────────────────────────────────
        // When a member sends a message, chat.js commits a writeBatch that updates
        // the room doc with: lastMessage, lastSenderEmail, lastSenderName,
        // lastUpdated, AND unreadCount (zeroing the sender's own key and
        // incrementing every recipient's key).
        //
        // The general member branch below intentionally restricts unreadCount
        // changes to the caller's own key only (for mark-as-read writes).
        // That constraint is correct for reads but it also blocks the send-message
        // batch because the batch touches OTHER members' unreadCount keys.
        //
        // This narrow branch permits exactly the send-message update pattern:
        //   • caller must be a confirmed member of the chat
        //   • only the send-metadata fields may be changed (no membership etc.)
        //   • lastSenderEmail must equal callerEmail() — proves who is sending
        // Any field outside this set (type, members, admins, …) is still blocked.
        (resource.data.members.hasAny([callerEmail()]) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessage', 'lastSenderEmail', 'lastSenderName',
                      'lastUpdated', 'lastMessageAt', 'unreadCount']) &&
          request.resource.data.lastSenderEmail == callerEmail()
        ) ||
        // ── Group-event room-metadata branch ──────────────────────────────────
        // When a group admin/member triggers a membership event (leave, remove,
        // add member, make/remove admin, approve join), chat.js writes a system
        // message to the messages subcollection AND updates the room doc with:
        //   lastMessage (event text), lastSenderEmail='system',
        //   lastUpdated, lastMessageAt, unreadCount (bump for all other members).
        // The send-message branch above blocks this because lastSenderEmail must
        // equal callerEmail() — it cannot be 'system'.
        // The general member branch below blocks lastMessage/lastSenderEmail/lastSenderName.
        // This narrow branch permits exactly the group-event update pattern:
        //   • caller must be a confirmed member of the chat
        //   • only metadata fields may be changed (no membership / type / admins)
        //   • lastSenderEmail must be 'system' — distinguishes this from real messages
        //   • group chats only
        (resource.data.members.hasAny([callerEmail()]) &&
          resource.data.type == 'group' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessage', 'lastSenderEmail', 'lastSenderName',
                      'lastUpdated', 'lastMessageAt', 'unreadCount']) &&
          request.resource.data.lastSenderEmail == 'system'
        ) ||
        // FIX DUPLICATE-CHAT: openChatRoom's runTransaction calls tx.update() on
        // the room doc when it already exists, writing memberNames, lastUpdated,
        // lastRead.<email>, and unreadCount.<email>=0 atomically so the RCM
        // snapshot triggered by this write already sees count=0 — eliminating the
        // race where the badge reappeared between the tx commit and the separate
        // markRoomRead write.
        // `name` and `members` are NOT in this allowlist, so group-rename and
        // member-injection attacks via this path are still impossible.
        // Per-user key guards on lastRead and unreadCount mirror the main member
        // branch below: only the caller's own keys may be written.
        //
        // BUG-OPENROOM-GROUP FIX: previously restricted to type=='private', but
        // openChatRoom is also called for group chats (to refresh memberNames and
        // zero the caller's unreadCount on open). The general member branch blocks
        // 'memberNames' writes, so group openChatRoom transactions were silently
        // denied. Removing the type restriction makes this branch apply to both
        // private and group rooms. 'members' and 'admins' remain outside the
        // affectedKeys allowlist, so member-injection / privilege-escalation
        // attacks via this path are still impossible.
        (resource.data.members.hasAny([callerEmail()]) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberNames', 'lastUpdated', 'lastRead', 'unreadCount']) &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastRead']) ||
            request.resource.data.get('lastRead', {}).keys()
              .hasOnly([callerEmail(), callerEmail().split('.')[0]])
          ) &&
          (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['unreadCount']) ||
            request.resource.data.get('unreadCount', {}).diff(
              resource.data.get('unreadCount', {})
            ).affectedKeys().hasOnly([callerEmail(), callerEmail().split('.')[0]])
          )
        ) ||
        (resource.data.members.hasAny([callerEmail()]) &&
          // BUG-1 FIX: block fields that must NOT be freely written by members.
          // Added 'name' (group display name) and 'memberNames' to prevent any
          // member from renaming the group or other members — those are admin-only.
          // 'blockedBy' is handled separately below.
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['type', 'createdBy', 'admins', 'inviteCode', 'members',
                     'name', 'memberNames']) &&
          (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['lastRead']) ||
            (resource.data.lastRead != null &&
              request.resource.data.lastRead
                .diff(resource.data.lastRead).affectedKeys()
                .hasOnly([callerEmail(), callerEmail().split('.')[0]])
            ) ||
            (resource.data.lastRead == null &&
              request.resource.data.lastRead.keys()
                .hasOnly([callerEmail(), callerEmail().split('.')[0]])
            )
          ) &&
          (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['unreadCount']) ||
            (resource.data.unreadCount != null &&
              request.resource.data.unreadCount
                .diff(resource.data.unreadCount).affectedKeys()
                // Accept both the correct flat key ("user@gmail.com") AND the
                // broken dot-split key ("user@gmail") that was created by the
                // old setDoc+merge writes. Both map to the caller's identity.
                .hasOnly([callerEmail(), callerEmail().split('.')[0]])
            ) ||
            (resource.data.unreadCount == null &&
              request.resource.data.unreadCount.keys()
                .hasOnly([callerEmail(), callerEmail().split('.')[0]])
            )
          ) &&
          // FIX BUG-5: pinnedBy is a per-user map keyed by email.  Without this
          // guard any chat member could write pinnedBy.<other@user.com>, silently
          // pinning or unpinning conversations in another member's sidebar.
          // Pattern mirrors the lastRead / unreadCount constraints above.
          (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['pinnedBy']) ||
            (resource.data.pinnedBy != null &&
              request.resource.data.pinnedBy
                .diff(resource.data.pinnedBy).affectedKeys()
                .hasOnly([callerEmail()])
            ) ||
            (resource.data.get('pinnedBy', null) == null &&
              request.resource.data.pinnedBy.keys().hasOnly([callerEmail()])
            )
          ) &&
          // FIX RULE-CLEAREDAT: "Clear Chat" writes clearedAt.<email>=<timestamp>
          // per-user so RCM can suppress the stale lastMessage preview.
          (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['clearedAt']) ||
            (resource.data.get('clearedAt', null) != null &&
              request.resource.data.clearedAt
                .diff(resource.data.clearedAt).affectedKeys()
                .hasOnly([callerEmail()])
            ) ||
            (resource.data.get('clearedAt', null) == null &&
              request.resource.data.clearedAt.keys().hasOnly([callerEmail()])
            )
          ) &&
          // FIX RULE-HIDDENFOR: "Delete for me" writes hiddenFor.<email>=true and
          // hiddenAt.<email>=<timestamp> on the room doc so the sidebar can exclude
          // it for this user.  Same per-user key pattern as pinnedBy/lastRead.
          (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['hiddenFor']) ||
            (resource.data.get('hiddenFor', null) != null &&
              request.resource.data.hiddenFor
                .diff(resource.data.hiddenFor).affectedKeys()
                .hasOnly([callerEmail()])
            ) ||
            (resource.data.get('hiddenFor', null) == null &&
              request.resource.data.hiddenFor.keys().hasOnly([callerEmail()])
            )
          ) &&
          (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['hiddenAt']) ||
            (resource.data.get('hiddenAt', null) != null &&
              request.resource.data.hiddenAt
                .diff(resource.data.hiddenAt).affectedKeys()
                .hasOnly([callerEmail()])
            ) ||
            (resource.data.get('hiddenAt', null) == null &&
              request.resource.data.hiddenAt.keys().hasOnly([callerEmail()])
            )
          ) &&
          // BUG-1 FIX (blockedBy): "Block user" writes blockedBy as an array.
          // Without this guard any member could add/remove any OTHER user's email
          // from blockedBy — e.g. unblocking a chat that the other person blocked.
          // Enforce that only the caller's own email is ever added or removed from
          // the array, mirroring the per-user key pattern used for pinnedBy etc.
          // arrayUnion / arrayRemove on a list → use toSet().difference() to check
          // exactly which email was mutated (same pattern as pendingRequests rule).
          (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['blockedBy']) ||
            (
              // Email added (block) must be caller only
              request.resource.data.get('blockedBy', []).toSet()
                .difference(resource.data.get('blockedBy', []).toSet())
                .hasOnly([callerEmail()]) &&
              // Email removed (unblock) must be caller only
              resource.data.get('blockedBy', []).toSet()
                .difference(request.resource.data.get('blockedBy', []).toSet())
                .hasOnly([callerEmail()])
            )
          )
        ) ||
        // ── Join-request writes (open / request-to-join groups) ───────────
        // FIX RULE-04 (original 3 bugs were fixed in a prior pass, but two new
        // bugs remained):
        //
        //   (d) pendingRequests is a list of MAP objects {email, name, requestedAt},
        //       NOT a list of plain strings. Calling .toSet().difference() on a
        //       list-of-maps and comparing against [callerEmail()] (a string set)
        //       can never match — the set difference yields maps, not strings.
        //       Fix: use size+index checks on the list, which work correctly for
        //       lists of maps in Firestore rules v2.
        //
        //   (e) The transaction in chat.js also writes dismissedRequests (via
        //       arrayRemove) when cleaning up an expired dismiss entry for the
        //       joining user. The old affectedKeys().hasOnly(['pendingRequests'])
        //       caused permission-denied for any user who had a prior dismiss entry,
        //       since dismissedRequests was not in the allowlist.
        //       Fix: expand to hasOnly(['pendingRequests', 'dismissedRequests']).
        //
        // Security: size checks ensure caller can only ADD exactly one
        // pendingRequests entry (their own) and REMOVE at most one
        // dismissedRequests entry. Bulk injection of other users is still blocked.
        (resource.data.type == 'group' &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['pendingRequests', 'dismissedRequests']) &&
          // Exactly one entry added to pendingRequests
          request.resource.data.get('pendingRequests', []).size() ==
            resource.data.get('pendingRequests', []).size() + 1 &&
          // The new entry must be the caller's own request object
          request.resource.data.pendingRequests[
            request.resource.data.pendingRequests.size() - 1
          ].email == callerEmail() &&
          // dismissedRequests may only shrink (caller removing their own expired entry)
          request.resource.data.get('dismissedRequests', []).size() <=
            resource.data.get('dismissedRequests', []).size()
        ) ||
        // BUG-2 FIX: Added 'name' and 'memberNames' to the admin-only allowlist so
        // group admins can rename the group and manage display names. Both were
        // previously blocked from the member branch above, so this restores admin
        // ability to perform those writes.
        (resource.data.type == 'group' &&
          resource.data.admins is list &&
          resource.data.admins.hasAny([callerEmail()]) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'memberNames', 'admins', 'inviteCode',
                      'pendingRequests', 'dismissedRequests', 'name'])
        ) ||
        (resource.data.members.hasAny([callerEmail()]) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'memberNames', 'admins']) &&
          !request.resource.data.members.hasAny([callerEmail()])
        )
      );
      // FIX RULE-06: private chat delete previously used `createdBy == callerEmail()`.
      // Private chat documents are created by openChatRoom via setDoc with only
      // { type, members, memberNames, lastUpdated } — the `createdBy` field is
      // NEVER written for private chats.  Using createdBy here means
      // resource.data.createdBy is always null, so null == callerEmail() is always
      // false, permanently blocking every non-admin user from deleting any private
      // chat.  Correct check: any member of the private chat may delete it
      // (both participants should be able to remove their conversation).
      // Group chats correctly keep the existing `createdBy` restriction.
      allow delete: if isSignedIn() && (
        resource.data.type == 'private'
          ? (resource.data.members.hasAny([callerEmail()]) || isAdmin())
          : ((resource.data.keys().hasAll(['createdBy']) &&
               resource.data.createdBy == callerEmail()) || isAdmin())
      );
      match /messages/{messageId} {
        function getChatOnce() {
          return get(/databases/$(database)/documents/chats/$(chatId));
        }
        function isChatMember() {
          let _chat = getChatOnce();
          return _chat != null && _chat.data.members.hasAny([callerEmail()]);
        }
        function getChatDoc() {
          return getChatOnce();
        }
        function isSystemMsgAllowed() {
          let _c = getChatDoc();
          return _c != null &&
                 _c.data.type == 'group' &&
                 request.resource.data.senderEmail == 'system';
        }
        allow read: if isSignedIn() && isChatMember();
        allow create: if isSignedIn() && (!isBanned() || isAdmin()) && (
          isChatMember()
            ? (request.resource.data.senderEmail == callerEmail() ||
               request.resource.data.senderEmail == 'system')
            : isSystemMsgAllowed()
        );
        allow update: if isSignedIn() && (
          isAdmin() ||
          (resource.data.senderEmail == callerEmail() &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['senderEmail', 'senderName', 'createdAt',
                       'replyTo', 'forwarded', 'seenBy'])) ||
          // FIX RULE-DELETEFOR: any chat member may stamp their own email onto
          // deletedFor (used by "Delete for me" / "Clear chat" — both only ever
          // add the caller's own email via arrayUnion).  Previously deletedFor was
          // in the sender-only blocked list, so clearing/deleting messages from
          // someone else's messages always got permission-denied.
          (isChatMember() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['deletedFor'])) ||
          // FIX RULE-SEENBY: seenBy (blue-tick delivery) is written by the *recipient*
          // via arrayUnion(callerEmail()) when they view a message — not by the sender.
          // seenBy was absent from every member-writable allowlist, silently denying
          // every blue-tick write. Add a narrow branch: member may only touch seenBy.
          // seenAt is a per-user map written alongside seenBy to record the exact time
          // each recipient saw the message — used by the "Message Info" panel.
          (isChatMember() &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['seenBy', 'deliveredTo', 'seenAt'])) ||
          (isChatMember() &&
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['text', 'imageUrl', 'voiceUrl', 'fileUrl',
                       'isDeletedForEveryone', 'senderEmail', 'senderName',
                       'edited', 'editedAt', 'replyTo', 'forwarded',
                       'fileName', 'fileMime', 'fileSize', '_deletedMediaUrls',
                       'attachments', 'deletedFor']))
        );
        // FIX RULE-MSG-DELETE: previously only the message sender or an admin
        // could delete a message.  This permanently blocked "Delete chat" from
        // working for private chats: deleting the whole room requires deleting ALL
        // messages, including ones sent by the other participant.
        // Fix: any confirmed member of the parent chat may delete any message in
        // that chat, in addition to the existing sender-only and admin paths.
        // isChatMember() is already used for read/create above, so no extra read
        // cost is introduced — Firestore caches the get() result within the same
        // rule evaluation.
        allow delete: if isSignedIn() && (
          resource.data.senderEmail == callerEmail() ||
          isChatMember() ||
          isAdmin()
        );
      }
      match /typing/{typingUserEmail} {
        function callerIsTypingMember() {
          let _c = get(/databases/$(database)/documents/chats/$(chatId));
          return _c != null && _c.data.members.hasAny([callerEmail()]);
        }
        allow read:  if isSignedIn() && callerIsTypingMember();
        allow write: if isSignedIn() &&
                        callerEmail() == typingUserEmail &&
                        callerIsTypingMember();
      }
      match /starred/{starredUserEmail} {
        function callerIsStarredMember() {
          let _c = get(/databases/$(database)/documents/chats/$(chatId));
          return _c != null && _c.data.members.hasAny([callerEmail()]);
        }
        allow read:  if isSignedIn() && callerEmail() == starredUserEmail;
        allow write: if isSignedIn() &&
                        callerEmail() == starredUserEmail &&
                        callerIsStarredMember();
      }
    }
  }
}